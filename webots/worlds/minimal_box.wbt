#VRML_SIM R2025a utf8

WorldInfo {
  basicTimeStep 16
}

Viewpoint {
  orientation -0.220 0.880 0.420 0.900
  position -2 -2 1.5
}

Background {
  skyColor [ 0.65 0.75 0.90 ]
}

DirectionalLight {
  ambientIntensity 1
  direction 0.3 0.3 -1
}

Solid {
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.15 0.1
      }
      geometry Box {
        size 1 1 1
      }
    }
  ]
}
